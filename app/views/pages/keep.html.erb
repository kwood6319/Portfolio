<div class="header p-4 mb-4 shadow-sm">
  <div class="row align-items-center">
    <!-- LEFT SIDE -->
    <div class="col-12 col-md-4 text-center mb-3 mb-md-0">
      <!-- IMAGE -->
      <%= image_tag "main pic.jpg", alt: "Katie", class: "profilepic mb-3" %>
      <!-- ICONS -->
      <div class="d-flex justify-content-center gap-3 social-icons">
        <%= link_to "https://google.com", target: "_blank" do %>
          <i class="fa-brands fa-github"></i>
        <% end %>
        <%= link_to "https://google.com", target: "_blank" do %>
          <i class="fa-brands fa-linkedin"></i>
        <% end %>
      </div>
    </div>
    <!-- RIGHT SIDE -->
    <div class="col-12 col-md-8 ps-md-5 text-center text-md-start">
      <h1 class="fw-bold mb-1 name">Katie</h1>
      <h4 class="mb-2 role">Full Stack Developer</h4>
      <p class="mb-3">
        Full Stack Developer specializing in Ruby on Rails,
        building practical and user-friendly web applications.
      </p>
      <div class="skills">
        <span class="badge skill-badge">Ruby</span>
        <span class="badge skill-badge">Rails</span>
        <span class="badge skill-badge">HTML</span>
        <span class="badge skill-badge">CSS</span>
        <span class="badge skill-badge">PostgreSQL</span>
      </div>
    </div>
  </div>
</div>
<div class="container mt-5">
  <!-- ABOUT -->
  <div class="abt-me p-4 mb-5 rounded shadow-sm">
    <div class="row align-items-center">
      <!-- IMAGE (comes first on mobile, second on desktop) -->
      <div class="col-md-5 text-center order-1 order-md-2">
        <%= image_tag "cats.jpg", alt: "3 cats, 2 black, 1 orange", class: "about-image" %>
      </div>
      <!-- TEXT -->
      <div class="col-md-7 order-2 order-md-1">
        <h3 class="section-title">About Me</h3>
        <p>
          I'm a Full Stack Developer based in Japan with a background in teaching.
          I enjoy solving problems, building user-friendly applications, and continuously improving my skills.
        </p>
      </div>
    </div>
  </div>
  <!-- PROJECTS -->
  <div class="myproj p-4 rounded shadow-sm mb-5">
    <h3 class="section-title mb-4">Projects</h3>
    <!-- PROJECT CARD -->
    <div class="project-card row mb-4 align-items-center">
      <!-- IMAGE -->
      <div class="col-md-4 text-center">
        <%= image_tag "cats.jpg", alt: "3 cats, 2 black, 1 orange", class: "about-image" %>
      </div>
      <!-- DETAILS -->
      <div class="col-md-8">
        <h5>Classroom Library</h5>
        <p>
          A web app for managing classroom books and student loans.
          Built with Ruby on Rails and PostgreSQL.
        </p>
        <a href="#" class="btn project-btn me-2">GitHub</a>
        <a href="#" class="btn project-btn-outline">Details</a>
      </div>
    </div>
    <!-- connectPet -->
    <div class="project-card row mb-4 align-items-center">
      <div class="col-md-3 text-center">
        <%= image_tag "connectPet.png", alt: "connectPet logo", class: "project-logo" %>
      </div>
      <div class="col-md-9">
        <h5>connectPet</h5>
        <p>
          A platform for connecting pet owners with services and communities.
        </p>
        <a href="#" class="btn project-btn me-2">GitHub</a>
        <a href="#" class="btn project-btn-outline">Details</a>
      </div>
    </div>
    <!-- GanbaAI -->
    <div class="project-card row align-items-center">
      <div class="col-md-4 text-center">
        <%= image_tag "GanbaAI.jpg", alt: "GanbaAI logo", class: "project-logo" %>
      </div>
      <div class="col-md-8">
        <h5>GanbaAI</h5>
        <p>
          An AI-powered productivity assistant designed to keep users motivated.
        </p>
        <a href="#" class="btn project-btn me-2">GitHub</a>
        <a href="#" class="btn project-btn-outline">Details</a>
      </div>
    </div>
  </div>
</div>
