<!-- NAVBAR PARTIAL -->
<%= render "shared/navbar" %>
<!-- HEADER -->
<section class="header">
  <div class="header-content">
    <div class="header-image">
      <%= image_tag "main pic.jpg", alt: "Katie", class: "profilepic mb-3" %>
    </div>
    <div class="header-text">
      <h1>Katie Wood</h1>
      <h2>Full Stack Developer</h2>
      <p>I'm a Full Stack Developer based in Japan with a background in teaching.
        I enjoy solving problems, building user-friendly applications, and continuously improving my skills.</p>
      <div class="skills">
        <span class="pill">Ruby</span>
        <span class="pill">Rails</span>
        <span class="pill">JavaScript</span>
        <span class="pill">HTML</span>
        <span class="pill">CSS</span>
      </div>
    </div>
  </div>
</section>
<!-- PROJECTS -->
<section id="projects" class="projects">
  <h2>Projects</h2>
  <div class="project-grid">
    <% @projects.each do |project| %>
      <div class="project-card">
        <%= image_tag "#{project.title}.jpg", alt: "#{project.title} screenshot", class: "project-image" %>
        <h3> <%= project.title %> </h3>
        <p> <%= project.description %> </p>
        <div class="skills">
          <% project.skills.each do |skill| %>
            <span class="pill-small"><%= skill %></span>
          <% end %>
        </div>
        <div class="project-links">
          <%= link_to "Repo", "#{project.link}", class: "btn", target: :_blank %>
          <%= link_to "Details", project_path(project), class: "btn-outline" %>
        </div>
      </div>
    <% end %>
    <div class="project-card">
      <%= image_tag "GanbaAI.jpg", alt: "GanbaAI logo", class: "project-image" %>
      <h3>GanbaAi</h3>
      <p>An AI-powered productivity assistant designed to keep users motivated.</p>
      <div class="skills">
        <span class="pill-small">Rails</span>
        <span class="pill-small">Stimulus</span>
        <span class="pill-small">SCSS</span>
        <span class="pill-small">HTML</span>
        <span class="pill-small">PostgreSQL</span>
        <span class="pill-small">Gemini</span>
        <span class="pill-small">Cloudinary</span>
        <span class="pill-small">Wicked</span>
      </div>
      <div class="project-links">
        <a href="https://github.com/kwood6319/GanbaAi" class="btn">Repo</a>
        <a href="#" class="btn-outline">Details</a>
      </div>
    </div>
    <% 5.times do |i| %>
      <div class="project-card">
        <div class="project-image">Image</div>
        <h3>Project <%= i + 1 %></h3>
        <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
        <div class="project-links">
          <a href="#" class="btn">Repo</a>
          <a href="#" class="btn-outline">Details</a>
        </div>
      </div>
    <% end %>
  </div>
</section>
<!-- CONTACT -->
<section id="contact" class="contact">
  <h2>Contact Me</h2>
  <form>
    <input type="text" placeholder="Your Name">
    <input type="email" placeholder="Your Email">
    <textarea placeholder="Your Message"></textarea>
    <button type="submit">Send Message</button>
  </form>
</section>
