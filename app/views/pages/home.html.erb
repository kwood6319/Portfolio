<div class="container mt-5">
  <!-- ABOUT -->
  <div class="abt-me p-4 mb-5 rounded shadow-sm">
    <div class="row align-items-center">
      <!-- TEXT -->
      <div class="col-md-7">
        <h3 class="section-title">About Me</h3>
        <p>
          I’m a Full Stack Developer based in Japan with a background in teaching.
          I enjoy solving problems, building user-friendly applications, and continuously improving my skills.
        </p>
      </div>
      <!-- IMAGE PLACEHOLDER -->
      <div class="col-md-5 text-center">
        <div class="img-placeholder">
          Image here
        </div>
      </div>
    </div>
  </div>
  <!-- PROJECTS -->
  <div class="myproj p-4 rounded shadow-sm mb-5">
    <h3 class="section-title mb-4">Projects</h3>
    <!-- PROJECT CARD -->
    <div class="project-card row mb-4 align-items-center">
      <!-- IMAGE -->
      <div class="col-md-4 text-center">
        <div class="img-placeholder">
          Project Image
        </div>
      </div>
      <!-- DETAILS -->
      <div class="col-md-8">
        <h5>Classroom Library</h5>
        <p>
          A web app for managing classroom books and student loans.
          Built with Ruby on Rails and PostgreSQL.
        </p>
        <a href="#" class="btn project-btn me-2">GitHub</a>
        <a href="#" class="btn project-btn-outline">Details</a>
      </div>
    </div>
    <!-- connectPet -->
    <div class="project-card row mb-4 align-items-center">
      <div class="col-md-3 text-center">
        <%= image_tag "connectPet.png", alt: "connectPet logo", class: "project-logo" %>
      </div>
      <div class="col-md-9">
        <h5>connectPet</h5>
        <p>
          A platform for connecting pet owners with services and communities.
        </p>
        <a href="#" class="btn project-btn me-2">GitHub</a>
        <a href="#" class="btn project-btn-outline">Details</a>
      </div>
    </div>
    <!-- GanbaAI -->
    <div class="project-card row align-items-center">
      <div class="col-md-4 text-center">
        <%= image_tag "GanbaAI.jpg", alt: "GanbaAI logo", class: "project-logo" %>
      </div>
      <div class="col-md-8">
        <h5>GanbaAI</h5>
        <p>
          An AI-powered productivity assistant designed to keep users motivated.
        </p>
        <a href="#" class="btn project-btn me-2">GitHub</a>
        <a href="#" class="btn project-btn-outline">Details</a>
      </div>
    </div>
  </div>
</div>
