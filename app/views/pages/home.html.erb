<section class="header">
  <div class="header-content">
    <div class="header-image">
      <%= image_tag "main pic.jpg", alt: "Katie", class: "profilepic mb-3" %>
    </div>
    <div class="header-text">
      <% if I18n.locale == :ja%>
        <h1>ウッド・ケイティー</h1>
        <h2>フルスタックエンジニア</h2>
        <p> 日本在住のフルスタックエンジニアで、教育分野での経験があります。
          課題解決やユーザーフレンドリーなアプリケーションの開発にやりがいを感じており、継続的なスキル向上にも取り組んでいます。</p>
      <% else %>
        <h1>Katie Wood</h1>
        <h2>Full Stack Developer</h2>
        <p>I'm a Full Stack Developer based in Japan with a background in teaching.
          I enjoy solving problems, building user-friendly applications, and continuously improving my skills.</p>
      <% end %>
      <div class="skills">
        <span class="pill">Ruby</span>
        <span class="pill">Rails</span>
        <span class="pill">JavaScript</span>
        <span class="pill">HTML</span>
        <span class="pill">CSS</span>
      </div>
    </div>
  </div>
</section>
<!-- PROJECTS -->
<section id="projects" class="projects">
  <h2>Projects</h2>
  <div class="project-grid">
    <% @projects.each do |project| %>
      <div class="project-card">
        <div class="project-image">
          <%= image_tag "#{project.image}", alt: "#{project.title} screenshot", class: "project-image" %>
        </div>
        <h3> <%= project.title %> </h3>
        <p> <%= project.description %> </p>
        <div class="skills">
          <% project.skills.each do |skill| %>
            <span class="pill-small"><%= skill %></span>
          <% end %>
        </div>
        <div class="project-links">
          <%= link_to "Repo", "#{project.link}", class: "btn", target: :_blank %>
          <%= link_to "Details", project_path(project, locale: I18n.locale), class: "btn-outline" %>
        </div>
      </div>
    <% end %>
  </div>
</section>
