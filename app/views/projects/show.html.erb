<div class="project-show">
  <!-- HEADER -->
  <section class="project-header">
    <div class="header-image">
      <div class="project-image">
        <% image_name = "#{@project.title}.jpg" %>
        <% if asset_exists?(image_name) %>
          <%= image_tag image_name %>
        <% else %>
          <div class="image-placeholder">Image</div>
        <% end %>
      </div>
    </div>
    <h1><%= @project.title %></h1>
    <!-- SKILLS -->
    <div class="project-meta">
      <div class="skills">
        <% @project.skills&.each do |skill| %>
          <span class="pill"><%= skill %></span>
        <% end %>
      </div>
    </div>
    <!-- EXTRA INFO -->
    <div class="project-extra">
      <p><strong>Team Size:</strong> <%= @project.team_size %></p>
      <% if @project.role != "" %>
        <p><strong>Role:</strong> <%= @project.role %></p>
      <% end %>
    </div>
    <p class="project-description">
      <%= @project.description %>
    </p>
  </section>
  <!-- STAGES -->
  <section class="project-stages">
    <% @stages.each do |stage| %>
      <div class="stage-card">
        <h2><%= stage.title %></h2>
        <div class="stage-content">
          <!-- IMAGE -->
          <div class="stage-image">
            <% image_name = "#{@project.title}#{stage.title}.jpg" %>
            <% if asset_exists?(image_name) %>
              <%= image_tag image_name %>
            <% else %>
              <div class="image-placeholder">Image</div>
            <% end %>
          </div>
          <!-- TEXT -->
          <div class="stage-text">
            <p><%= stage.description %></p>
          </div>
        </div>
      </div>
    <% end %>
  </section>
  <!-- BACK LINK -->
  <div class="back-link">
    <%= link_to "← Back to Projects", root_path, class: "btn-outline" %>
    <%= link_to "Visit the GitHub repo →", "#{@project.link}", class: "btn", target: :_blank %>
  </div>
</div>
